# ============================================
# BeyCRM Environment Variables Template
# ============================================

# Development
DATABASE_URL=postgresql://beyercrm:beyercrm_dev_password@localhost:5432/beyercrm
JWT_SECRET=change-this-to-a-long-random-string-in-production
NEXTAUTH_SECRET=dev_secret_change_in_production
NEXTAUTH_URL=http://localhost:3000
NOMINATIM_URL=https://nominatim.openstreetmap.org
BCRYPT_ROUNDS=10
# OPENCAGE_API_KEY=your_open cage_api_key_here

# Production (on VPS, set these via environment or .env file)
